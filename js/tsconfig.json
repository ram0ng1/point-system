{
  "extends": "flarum-tsconfig",
  "include": [
    "src/**/*",
    "../vendor/*/*/js/dist-typings/@types/**/*",
    "../../../vendor/*/*/js/dist-typings/@types/**/*"
  ],
  "compilerOptions": {
    "rootDir": "./src",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "flarum/*": [
        "../vendor/flarum/core/js/dist-typings/*",
        "../../../vendor/flarum/core/js/dist-typings/*"
      ]
    }
  }
}
